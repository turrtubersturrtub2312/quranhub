{
  "title": "Quranhub",
  "description": "",
  "head": "<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />",
  "htmlAttrs": "lang=\"en\" class=\"\"",
  "tags": [],
  "activeEditor": "markup",
  "markup": {
    "language": "html",
    "content": "<!DOCTYPE html>\r\n<html lang=\"ms\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Quran Pro - Loading Stabil</title>\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Amiri&family=Poppins:wght@300;400;600&display=swap\" rel=\"stylesheet\">\r\n    <style>\r\n        :root { --bg: #f4f7f6; --card: #ffffff; --text: #2c3e50; --accent: #27ae60; --border: #ddd; }\r\n        \r\n        body.premium-theme {\r\n            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1500622855241-077d5163f995?auto=format&fit=crop&w=1350&q=80');\r\n            background-size: cover; background-attachment: fixed;\r\n            --card: rgba(255, 255, 255, 0.2); --text: #fff; --border: rgba(255,255,255,0.3); backdrop-filter: blur(10px);\r\n        }\r\n\r\n        body { font-family: 'Poppins', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; transition: 0.5s; overflow-x: hidden; }\r\n        .container { max-width: 900px; margin: auto; }\r\n\r\n        /* --- LOADING SCREEN (STABIL & DIKUNCI) --- */\r\n        #loading-screen { \r\n            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; \r\n            background: #ffffff; display: flex; flex-direction: column; \r\n            justify-content: center; align-items: center; z-index: 100000;\r\n            transition: opacity 0.8s ease;\r\n        }\r\n        .progress-box { width: 280px; height: 12px; background: #e0e0e0; border-radius: 20px; margin-top: 20px; overflow: hidden; border: 1px solid #ccc; }\r\n        #progress-fill { width: 0%; height: 100%; background: var(--accent); transition: width 0.1s linear; }\r\n        #ld-text { font-size: 2rem; font-weight: bold; color: var(--accent); margin: 0; }\r\n\r\n        /* --- UI COMPONENTS --- */\r\n        .status-bar { display: flex; justify-content: space-between; align-items: center; background: var(--card); padding: 15px; border-radius: 15px; margin-bottom: 20px; border: 1px solid var(--border); gap: 10px; }\r\n        .btn { padding: 10px 18px; border-radius: 8px; border: none; cursor: pointer; font-weight: bold; transition: 0.3s; }\r\n        .btn-nabi { background: #3498db; color: white; }\r\n        .btn-premium { background: gold; color: #333; }\r\n        .btn-back { background: var(--accent); color: white; margin-bottom: 20px; }\r\n\r\n        #nabiPage, #ayatPage { display: none; }\r\n        .video-container { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; margin-bottom: 20px; border: 2px solid var(--accent); }\r\n        .video-container iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }\r\n        \r\n        .doa-card { background: var(--card); padding: 20px; border-radius: 12px; margin-bottom: 15px; border-left: 6px solid var(--accent); border: 1px solid var(--border); }\r\n        .doa-arab { font-family: 'Amiri'; font-size: 26px; text-align: right; direction: rtl; margin-bottom: 10px; }\r\n\r\n        .surah-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px; }\r\n        .card { background: var(--card); padding: 20px; border-radius: 12px; border: 1px solid var(--border); cursor: pointer; display: flex; justify-content: space-between; align-items: center; transition: 0.3s; }\r\n        .card:hover { transform: translateY(-5px); border-color: var(--accent); }\r\n        .ar-name { font-family: 'Amiri'; font-size: 24px; color: var(--accent); }\r\n\r\n        .teks-arab { font-family: 'Amiri'; font-size: 32px; text-align: right; direction: rtl; line-height: 2.6; border-bottom: 1px solid var(--border); padding-bottom: 15px; margin-top: 20px; }\r\n    </style>\r\n</head>\r\n<body>\r\n\r\n    <div id=\"loading-screen\">\r\n        <h1 id=\"ld-text\">0%</h1>\r\n        <div class=\"progress-box\">\r\n            <div id=\"progress-fill\"></div>\r\n        </div>\r\n        <p style=\"margin-top:10px; color:#555;\">Menyiapkan Website</p>\r\n    </div>\r\n\r\n    <div class=\"container\">\r\n        <div class=\"status-bar\">\r\n            <div>Goal: <span id=\"goalVal\" style=\"font-weight:bold; color:white(--accent); font-size:1.2rem;\">0</span> ⚽</div>\r\n            <div style=\"display:flex; gap:10px;\">\r\n                <button class=\"btn btn-nabi\" onclick=\"showNabiPage()\">Doa & Kisah Nabi</button>\r\n                <button class=\"btn btn-premium\" onclick=\"togglePremium()\">👑 Upgrade to Premium</button>\r\n            </div>\r\n        </div>\r\n\r\n        <div id=\"homePage\">\r\n            <div id=\"solatDisplay\" style=\"text-align:center; margin-bottom:20px; font-size: 14px; font-weight:bold;\">Memuatkan waktu solat...</div>\r\n            <div class=\"surah-grid\" id=\"listSurah\"></div>\r\n        </div>\r\n\r\n        <div id=\"ayatPage\">\r\n            <button class=\"btn btn-back\" onclick=\"goHome()\">← Kembali ke Senarai</button>\r\n            <h2 id=\"judulSurah\" style=\"text-align: center; color: var(--accent);\"></h2>\r\n            <div id=\"contentAyat\"></div>\r\n        </div>\r\n\r\n        <div id=\"nabiPage\">\r\n            <button class=\"btn btn-back\" onclick=\"goHome()\">← Kembali ke Utama</button>\r\n            <h2 style=\"color:var(--accent);\">Kisah Nabi (Channel: Kisah Islami)</h2>\r\n            <div class=\"video-container\">\r\n                <iframe src=\"https://www.youtube.com/embed/videoseries?list=PLyS9_0-A0p_Y0_Vw8K_0WosP5Wv0-e0Hh\" frameborder=\"0\" allowfullscreen></iframe>\r\n            </div>\r\n            \r\n            <h2 style=\"color:var(--accent); margin-top:30px;\">Hafalan Doa Pilihan</h2>\r\n            <div class=\"doa-card\">\r\n                <div class=\"doa-arab\">رَبَّنَآ اٰتِنَا فِى الدُّنْيَا حَسَنَةً وَّفِى الْاٰخِرَةِ حَسَنَةً وَّقِنَا عَذَابَ النَّارِ</div>\r\n                <strong>Doa Sapu Jagat</strong>\r\n                <p>Maksud: Berilah kami kebaikan di dunia dan akhirat serta pelihara kami dari api neraka.</p>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <script>\r\n        let goals = parseInt(localStorage.getItem('goals')) || 0;\r\n        let isPremium = localStorage.getItem('isPro') === 'true';\r\n\r\n        // --- SISTEM LOADING 0-100% (STABIL) ---\r\n        function startLoading() {\r\n            let percent = 0;\r\n            const fill = document.getElementById('progress-fill');\r\n            const text = document.getElementById('ld-text');\r\n            const screen = document.getElementById('loading-screen');\r\n\r\n            const timer = setInterval(() => {\r\n                percent++;\r\n                text.innerText = percent + \"%\";\r\n                fill.style.width = percent + \"%\";\r\n\r\n                if (percent >= 100) {\r\n                    clearInterval(timer);\r\n                    setTimeout(() => {\r\n                        screen.style.opacity = '0';\r\n                        setTimeout(() => {\r\n                            screen.style.display = 'none';\r\n                        }, 800);\r\n                    }, 400);\r\n                }\r\n            }, 35); // Ditetapkan pada 35ms supaya loading nampak real (anggaran 3.5 saat)\r\n        }\r\n\r\n        window.addEventListener('load', () => {\r\n            startLoading();\r\n            updateUI();\r\n            muatWaktuSolat();\r\n            muatSenaraiSurah();\r\n        });\r\n\r\n        function updateUI() {\r\n            document.getElementById('goalVal').innerText = goals;\r\n            if(isPremium) document.body.classList.add('premium-theme');\r\n        }\r\n\r\n        async function muatWaktuSolat() {\r\n            try {\r\n                const res = await fetch('https://api.aladhan.com/v1/timingsByCity?city=Kuala%20Lumpur&country=Malaysia&method=11');\r\n                const d = await res.json();\r\n                const t = d.data.timings;\r\n                document.getElementById('solatDisplay').innerText = `Subuh: ${t.Fajr} | Zohor: ${t.Dhuhr} | Asar: ${t.Asr} | Maghrib: ${t.Maghrib} | Isyak: ${t.Isha}`;\r\n            } catch(e) { document.getElementById('solatDisplay').innerText = \"Waktu Solat (Offline)\"; }\r\n        }\r\n\r\n        async function muatSenaraiSurah() {\r\n            try {\r\n                const res = await fetch('https://api.quran.com/api/v4/chapters?language=ms');\r\n                const data = await res.json();\r\n                const list = document.getElementById('listSurah');\r\n                list.innerHTML = \"\";\r\n                data.chapters.forEach(s => {\r\n                    const card = document.createElement('div');\r\n                    card.className = 'card';\r\n                    card.onclick = () => bukaSurah(s.id, s.name_simple);\r\n                    card.innerHTML = `<div><strong>${s.id}. ${s.name_simple}</strong><br><small>${s.verses_count} Ayat</small></div><div class=\"ar-name\">${s.name_arabic}</div>`;\r\n                    list.appendChild(card);\r\n                });\r\n            } catch(e) { console.log(\"Gagal muat senarai\"); }\r\n        }\r\n\r\n        async function bukaSurah(id, nama) {\r\n            document.getElementById('homePage').style.display = 'none';\r\n            document.getElementById('nabiPage').style.display = 'none';\r\n            document.getElementById('ayatPage').style.display = 'block';\r\n            document.getElementById('judulSurah').innerText = \"Surah \" + nama;\r\n            const area = document.getElementById('contentAyat');\r\n            area.innerHTML = \"<p style='text-align:center;'>Memuatkan Kalam Allah...</p>\";\r\n\r\n            try {\r\n                const res = await fetch(`https://api.quran.com/api/v4/quran/verses/uthmani?chapter_number=${id}`);\r\n                const data = await res.json();\r\n                area.innerHTML = \"\";\r\n                data.verses.forEach((v, i) => {\r\n                    area.innerHTML += `<div class=\"teks-arab\">${v.text_uthmani} (${i+1})</div>`;\r\n                });\r\n\r\n                goals += 3;\r\n                if(id == 87) { alert(\"RAHSIA AL-A'LA DITEMUI! +573 GOAL!\"); goals += 573; }\r\n                localStorage.setItem('goals', goals);\r\n                updateUI();\r\n                window.scrollTo(0,0);\r\n            } catch(e) { area.innerHTML = \"Ralat memuatkan ayat.\"; }\r\n        }\r\n\r\n        function showNabiPage() {\r\n            document.getElementById('homePage').style.display = 'none';\r\n            document.getElementById('ayatPage').style.display = 'none';\r\n            document.getElementById('nabiPage').style.display = 'block';\r\n            window.scrollTo(0,0);\r\n        }\r\n\r\n        function goHome() {\r\n            document.getElementById('homePage').style.display = 'block';\r\n            document.getElementById('ayatPage').style.display = 'none';\r\n            document.getElementById('nabiPage').style.display = 'none';\r\n        }\r\n\r\n        function togglePremium() {\r\n            if(isPremium) { alert(\"Anda sudah Pro!\"); return; }\r\n            if(goals >= 573) {\r\n                goals -= 573; isPremium = true;\r\n                localStorage.setItem('goals', goals);\r\n                localStorage.setItem('isPro', 'true');\r\n                updateUI();\r\n                alert(\"Premium Aktif! Selamat menikmati tema Syurga.\");\r\n            } else {\r\n                alert(\"Goal tidak cukup (Perlu Bayar goal 573)\");\r\n            }\r\n        }\r\n    </script>\r\n</body>\r\n</html>"
  },
