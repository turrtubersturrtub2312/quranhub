{
  "title": "Quranhub",
  "description": "",
  "head": "<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />",
  "htmlAttrs": "lang=\"en\" class=\"\"",
  "tags": [],
  "activeEditor": "markup",
  "markup": {
    "language": "html",
    "content": "<!DOCTYPE html>\r\n<html lang=\"ms\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Quranhub V2 - Mega Update</title>\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Amiri&family=Poppins:wght@300;400;600&display=swap\" rel=\"stylesheet\">\r\n    <style>\r\n        :root { --bg: #f4f7f6; --card: #ffffff; --text: #2c3e50; --accent: #27ae60; --border: #ddd; }\r\n        body.premium-theme {\r\n            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1500622855241-077d5163f995?auto=format&fit=crop&w=1350&q=80');\r\n            background-size: cover; background-attachment: fixed;\r\n            --card: rgba(255, 255, 255, 0.2); --text: #fff; --border: rgba(255,255,255,0.3); backdrop-filter: blur(10px);\r\n        }\r\n        body { font-family: 'Poppins', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; transition: 0.5s; }\r\n        .container { max-width: 900px; margin: auto; }\r\n\r\n        /* LOADING SCREEN */\r\n        #loading-screen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: white; display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 100000; transition: 0.5s; }\r\n        .progress-box { width: 250px; height: 10px; background: #eee; border-radius: 10px; overflow: hidden; margin-top: 15px; }\r\n        #progress-fill { width: 0%; height: 100%; background: var(--accent); }\r\n\r\n        /* HEADER & STATS */\r\n        .status-bar { display: flex; justify-content: space-between; align-items: center; background: var(--card); padding: 15px; border-radius: 15px; border: 1px solid var(--border); margin-bottom: 20px; }\r\n        #goalVal { color: #ffcc00; font-weight: bold; font-size: 1.4rem; } /* Update Warna Nombor Goal */\r\n\r\n        /* UPDATE 1: KHATAM TRACKER */\r\n        .khatam-box { background: var(--accent); color: white; padding: 15px; border-radius: 12px; margin-bottom: 20px; }\r\n        .progress-khatam { background: rgba(255,255,255,0.3); height: 8px; border-radius: 5px; margin-top: 10px; }\r\n        #khatam-fill { background: white; height: 100%; width: 0%; border-radius: 5px; transition: 1s; }\r\n\r\n        /* UPDATE 4: AUDIO SYNC HIGHLIGHT */\r\n        .reading-ayat { padding: 15px; border-radius: 10px; transition: 0.3s; margin-bottom: 10px; border-bottom: 1px solid var(--border); }\r\n        .reading-ayat.active { background: rgba(39, 174, 96, 0.2); border-left: 5px solid var(--accent); }\r\n        .teks-arab { font-family: 'Amiri'; font-size: 30px; text-align: right; direction: rtl; line-height: 2.2; }\r\n\r\n        /* UPDATE 2 & 5: TADABBUR & BOOKMARK */\r\n        .actions { display: flex; gap: 10px; margin-top: 10px; }\r\n        .btn-sm { padding: 5px 10px; font-size: 12px; border-radius: 5px; border: none; cursor: pointer; }\r\n        .note-area { width: 100%; margin-top: 10px; display: none; padding: 10px; border-radius: 5px; border: 1px solid var(--border); }\r\n\r\n        .surah-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px; }\r\n        .card { background: var(--card); padding: 20px; border-radius: 12px; border: 1px solid var(--border); cursor: pointer; display: flex; justify-content: space-between; align-items: center; }\r\n        \r\n        .btn { padding: 10px 15px; border-radius: 8px; border: none; cursor: pointer; font-weight: bold; }\r\n        #homePage, #ayatPage { display: none; }\r\n    </style>\r\n</head>\r\n<body>\r\n\r\n    <div id=\"loading-screen\">\r\n        <h1 id=\"ld-text\">0%</h1>\r\n        <div class=\"progress-box\"><div id=\"progress-fill\"></div></div>\r\n    </div>\r\n\r\n    <div class=\"container\">\r\n        <div class=\"status-bar\">\r\n            <div>Goal: <span id=\"goalVal\">0</span> ⚽</div>\r\n            <div style=\"display:flex; gap:10px;\">\r\n                <button class=\"btn\" style=\"background:#3498db; color:white;\" onclick=\"bukaBookmarks()\">⭐ Simpanan</button>\r\n                <button class=\"btn\" style=\"background:gold;\" onclick=\"togglePremium()\">👑 Get A Pro</button>\r\n            </div>\r\n        </div>\r\n\r\n        <div class=\"khatam-box\" id=\"khatamUI\">\r\n            <strong>Progres Khatam 30 Juzuk</strong>\r\n            <div class=\"progress-khatam\"><div id=\"khatam-fill\"></div></div>\r\n            <small id=\"khatamText\">0 dari 114 Surah selesai</small>\r\n        </div>\r\n\r\n        <div id=\"homePage\" style=\"display:block;\">\r\n            <div class=\"surah-grid\" id=\"listSurah\"></div>\r\n        </div>\r\n\r\n        <div id=\"ayatPage\">\r\n            <button class=\"btn\" style=\"background:var(--accent); color:white; margin-bottom:20px;\" onclick=\"goHome()\">← Kembali</button>\r\n            <h2 id=\"judulSurah\" style=\"text-align:center;\"></h2>\r\n            <div id=\"contentAyat\"></div>\r\n        </div>\r\n    </div>\r\n\r\n    <script>\r\n        let goals = parseInt(localStorage.getItem('goals')) || 0;\r\n        let isPremium = localStorage.getItem('isPro') === 'true';\r\n        let khatamCount = JSON.parse(localStorage.getItem('khatamCount')) || [];\r\n        let bookmarks = JSON.parse(localStorage.getItem('bookmarks')) || [];\r\n\r\n        window.onload = () => {\r\n            // Loading 0-100%\r\n            let p = 0;\r\n            let int = setInterval(() => {\r\n                p++;\r\n                document.getElementById('ld-text').innerText = p + \"%\";\r\n                document.getElementById('progress-fill').style.width = p + \"%\";\r\n                if(p >= 100) { clearInterval(int); document.getElementById('loading-screen').style.display='none'; }\r\n            }, 20);\r\n\r\n            updateUI();\r\n            muatSenaraiSurah();\r\n        };\r\n\r\n        function updateUI() {\r\n            document.getElementById('goalVal').innerText = goals;\r\n            if(isPremium) document.body.classList.add('premium-theme');\r\n            \r\n            // Update Khatam Progress\r\n            const perc = (khatamCount.length / 114) * 100;\r\n            document.getElementById('khatam-fill').style.width = perc + \"%\";\r\n            document.getElementById('khatamText').innerText = `${khatamCount.length} dari 114 Surah dibaca`;\r\n        }\r\n\r\n        async function muatSenaraiSurah() {\r\n            const res = await fetch('https://api.quran.com/api/v4/chapters?language=ms');\r\n            const data = await res.json();\r\n            const list = document.getElementById('listSurah');\r\n            data.chapters.forEach(s => {\r\n                const card = document.createElement('div');\r\n                card.className = 'card';\r\n                card.onclick = () => bukaSurah(s.id, s.name_simple);\r\n                card.innerHTML = `<div><strong>${s.id}. ${s.name_simple}</strong></div><div style=\"font-family:Amiri; color:var(--accent); font-size:20px;\">${s.name_arabic}</div>`;\r\n                list.appendChild(card);\r\n            });\r\n        }\r\n\r\n        async function bukaSurah(id, nama) {\r\n            document.getElementById('homePage').style.display = 'none';\r\n            document.getElementById('ayatPage').style.display = 'block';\r\n            document.getElementById('judulSurah').innerText = \"Surah \" + nama;\r\n            const area = document.getElementById('contentAyat');\r\n            area.innerHTML = \"Memuatkan...\";\r\n\r\n            const res = await fetch(`https://api.quran.com/api/v4/quran/verses/uthmani?chapter_number=${id}`);\r\n            const data = await res.json();\r\n            \r\n            area.innerHTML = \"\";\r\n            data.verses.forEach((v, i) => {\r\n                const key = `${id}:${i+1}`;\r\n                area.innerHTML += `\r\n                    <div class=\"reading-ayat\" id=\"ayat-${i}\">\r\n                        <div class=\"teks-arab\">${v.text_uthmani}</div>\r\n                        <div class=\"actions\">\r\n                            <button class=\"btn-sm\" style=\"background:#f1c40f\" onclick=\"mainAudio('${v.verse_key}', ${i})\">▶️ Dengar</button>\r\n                            <button class=\"btn-sm\" style=\"background:#3498db; color:white;\" onclick=\"saveBookmark('${key}')\">⭐ Simpan</button>\r\n                            <button class=\"btn-sm\" style=\"background:#95a5a6; color:white;\" onclick=\"toggleNote(${i})\">✍️ Tadabbur</button>\r\n                        </div>\r\n                        <textarea id=\"note-${i}\" class=\"note-area\" placeholder=\"Tulis nota tadabbur anda...\"></textarea>\r\n                    </div>`;\r\n            });\r\n\r\n            // Update Khatam Tracker\r\n            if(!khatamCount.includes(id)) {\r\n                khatamCount.push(id);\r\n                localStorage.setItem('khatamCount', JSON.stringify(khatamCount));\r\n            }\r\n            \r\n            goals += 3;\r\n            if(id == 87) { alert(\"RAHSIA AL-A'LA! +573 GOAL\"); goals += 573; }\r\n            localStorage.setItem('goals', goals);\r\n            updateUI();\r\n            window.scrollTo(0,0);\r\n        }\r\n\r\n        // UPDATE 4: AUDIO SYNC (Highlight ayat)\r\n        function mainAudio(verseKey, index) {\r\n            // Reset highlight\r\n            document.querySelectorAll('.reading-ayat').forEach(el => el.classList.remove('active'));\r\n            // Highlight ayat semasa\r\n            document.getElementById(`ayat-${index}`).classList.add('active');\r\n            \r\n            const url = `https://audio.qurancentral.com/mishary-rashid-alafasy/mishary-rashid-alafasy-${verseKey.replace(':', '')}.mp3`;\r\n            const audio = new Audio(url);\r\n            audio.play();\r\n            audio.onended = () => document.getElementById(`ayat-${index}`).classList.remove('active');\r\n        }\r\n\r\n        // UPDATE 2: TADABBUR\r\n        function toggleNote(index) {\r\n            const note = document.getElementById(`note-${index}`);\r\n            note.style.display = (note.style.display === 'block') ? 'none' : 'block';\r\n        }\r\n\r\n        // UPDATE 5: BOOKMARK\r\n        function saveBookmark(key) {\r\n            if(!bookmarks.includes(key)) {\r\n                bookmarks.push(key);\r\n                localStorage.setItem('bookmarks', JSON.stringify(bookmarks));\r\n                alert(\"Ayat disimpan dalam Bookmarks!\");\r\n            }\r\n        }\r\n\r\n        function goHome() {\r\n            document.getElementById('homePage').style.display = 'block';\r\n            document.getElementById('ayatPage').style.display = 'none';\r\n            updateUI();\r\n        }\r\n\r\n        function togglePremium() {\r\n            if(goals >= 573) { goals -= 573; isPremium = true; localStorage.setItem('isPro', 'true'); updateUI(); alert(\"Premium Aktif!\"); }\r\n            else { alert(\"Goal tidak cukup!\"); }\r\n        }\r\n    </script>\r\n</body>\r\n</html>"
  },
